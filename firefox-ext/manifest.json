{
  "manifest_version": 2,
  "name": "Discogs Label Printer",
  "version": "1.6",
  "description": "Print dt_label vinyl sleeve labels from Discogs release pages",

  "permissions": [
    "activeTab",
    "menus",
    "storage",
    "tabs"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_popup": "popup.html",
    "default_title": "Print Label"
  },

  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "discogs-label-printer@discogstool2",
      "strict_min_version": "109.0"
    }
  }
}
