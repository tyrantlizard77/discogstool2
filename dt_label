# ── Label size profiles ───────────────────────────────────────────────────────

# ── Shared layout constants (used by render_label AND _continuous_height) ─────
# _continuous_height() predicts the pixel height that render_label() will
# produce for a given track list.  Both functions use these constants — if
# they ever diverge, test_continuous_height_matches_render will catch it.

_TRACK_ROW_H  = 88   # px per track row
_SIDE_HDR_H   = 44   # px for a side header row
_LINE_SPACING = 55   # px between note ruling lines

# Header heights measured by tracing render_label y increments:
#   normal:       artist(70)+title(70)+gap+div(28)+label(46)+genre(46)+gap+div(26) = 286
#   continuation: compact-hdr(46)+gap+div(26)                                      =  72
#   +disc_info:   +40 in either case
_HDR_H = {"normal": 286, "continuation": 72, "disc_extra": 40}

# Extra px added per track row when its title wraps to a second line.
# Must match the value used in render_label().
_EXTRA_LINE_H = 50

# Extra px added to the header when the release title wraps to a second line.
# (58 px between title lines; original 70 px spacing applies to the last line.)
_TITLE_WRAP_LINE_H = 58

# QR code size (px).  Used in both render_label() and _continuous_height() so the
# two stay in sync.  ~17 mm at 300 DPI — scan-able from across a record shelf.
_QR_SIZE = 200

# Maximum label height for continuous stock — must fit on a 12" record sleeve.
MAX_CONTINUOUS_PX = 12 * 300   # 3600 px at 300 DPI

# Height at which a continuous label is considered full and a continuation
# label should be started.  Slightly under the physical sleeve limit.
MAX_LABEL_HEIGHT_PX = int(11.5 * 300)  # 3450 px


