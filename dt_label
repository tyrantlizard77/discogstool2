# ── Printer config (dotfile) ──────────────────────────────────────────────────

def load_config():
    """Load saved printer/profile settings from ~/.discogstool/label_config."""
    path = util.userfile(CONFIG_FILE)
    config = {}
    if os.path.exists(path):
        with open(path, "r") as f:
            for line in f:
                line = line.strip()
                if "=" in line and not line.startswith("#"):
                    k, v = line.split("=", 1)
                    config[k.strip()] = v.strip()
    return config


def save_config(config):
    """Persist printer/profile settings to ~/.discogstool/label_config."""
    path = util.userfile(CONFIG_FILE)
    with open(path, "w") as f:
        f.write("# dt_label configuration — auto-updated by --printer / --model / --label-profile\n")
        for k, v in config.items():
            f.write(f"{k}={v}\n")


# ── Font loading ──────────────────────────────────────────────────────────────

# Search order is macOS-first since that's the primary platform.
_FONT_CANDIDATES = {
    "regular": [
        "/System/Library/Fonts/Supplemental/Arial.ttf",
        "/Library/Fonts/Arial.ttf",
        "/usr/share/fonts/truetype/liberation/LiberationSans-Regular.ttf",
        "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf",
    ],
    "bold": [
        "/System/Library/Fonts/Supplemental/Arial Bold.ttf",
        "/Library/Fonts/Arial Bold.ttf",
        "/usr/share/fonts/truetype/liberation/LiberationSans-Bold.ttf",
        "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
    ],
    "condensed": [
        "/System/Library/Fonts/Supplemental/Arial Narrow.ttf",
        "/Library/Fonts/Arial Narrow.ttf",
        "/usr/share/fonts/truetype/dejavu/DejaVuSansCondensed.ttf",
        "/usr/share/fonts/truetype/liberation/LiberationSans-Regular.ttf",
    ],
    # CJK fallback — used whenever text contains Japanese/Chinese/Korean characters.
    # macOS ships Hiragino; Linux typically has Noto CJK.
    "cjk": [
        "/System/Library/Fonts/ヒラギノ角ゴシック W3.ttc",
        "/System/Library/Fonts/Hiragino Sans GB.ttc",
        "/usr/share/fonts/opentype/noto/NotoSansCJKjp-Regular.otf",
        "/usr/share/fonts/truetype/noto/NotoSansCJK-Regular.ttc",
        "/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc",
    ],
}

_font_path_cache = {}


def _find_font_path(style):
    if style in _font_path_cache:
        return _font_path_cache[style]
    for path in _FONT_CANDIDATES.get(style, _FONT_CANDIDATES["regular"]):
        if os.path.exists(path):
            _font_path_cache[style] = path
            return path
    _font_path_cache[style] = None
    return None


def make_font(style, size):
    """Return an ImageFont, falling back to Pillow's built-in if needed."""
    path = _find_font_path(style)
    if path:
        return ImageFont.truetype(path, size)
    return ImageFont.load_default()


def _needs_cjk(text):
    """Return True if text contains CJK, Hiragana, Katakana, or Hangul characters."""
    return any(
        0x2E80 <= ord(ch) <= 0x9FFF or  # CJK radicals, Hiragana, Katakana, CJK Unified
        0xAC00 <= ord(ch) <= 0xD7FF or  # Hangul syllables
        0xF900 <= ord(ch) <= 0xFAFF     # CJK Compatibility ideographs
        for ch in text
    )


def _font_for(style, size, text):
    """Like make_font but upgrades to the CJK font when text requires it."""
    if _needs_cjk(text):
        path = _find_font_path("cjk")
        if path:
            return ImageFont.truetype(path, size)
    return make_font(style, size)


# ── Track grouping ────────────────────────────────────────────────────────────

def get_side(position):
    """Extract the side letter(s) from a position string like 'A1', 'B2', 'AA1'.
    Returns '' for purely numeric positions."""
    if not position:
        return ""
    m = re.match(r"^([A-Za-z]+)", position.strip())
    return m.group(1).upper() if m else ""


def side_to_disc(side):
    """Map a side letter to a disc number.  A/B → 1, C/D → 2, E/F → 3 …
    Multi-letter sides (AA, BB …) map the same way using the first character."""
    if not side:
        return 1
    idx = ord(side[0].upper()) - ord("A")
    return (idx // 2) + 1


def group_tracks_by_disc(release):
    """Return {disc_num: {side_letter: [(global_idx, DiscogsTrack), …]}} preserving order.

    global_idx is the 0-based index into release.getTrack(i), which matches
    the keys returned by BeatportMatcher.find_bpms().
    """
    discs = {}
    for i in range(release.getTotalTracks()):
        track = release.getTrack(i)
        side  = get_side(track["position"])
        disc  = side_to_disc(side) if side else 1
        discs.setdefault(disc, {}).setdefault(side, []).append((i, track))
    return discs


def flatten_discs(discs):
    """Flatten disc/side groups into [(side_letter, global_idx, DiscogsTrack), …] in order."""
    result = []
    for disc_num in sorted(discs):
        for side in sorted(discs[disc_num]):
            for idx, track in discs[disc_num][side]:
                result.append((side, idx, track))
    return result


# ── Drawing helpers ───────────────────────────────────────────────────────────

def truncate_text(draw, text, font, max_width):
    """Shorten text with a trailing ellipsis so it fits within max_width pixels."""
    if draw.textlength(text, font=font) <= max_width:
        return text
    while text:
        text = text[:-1]
        candidate = text.rstrip() + "\u2026"
        if draw.textlength(candidate, font=font) <= max_width:
            return candidate
    return "\u2026"


# Discogs appends " (2)", " (3)" etc. to disambiguate artists with the same name.
# These are database artefacts and should not appear on printed labels.
_DISAMBIG_RE = re.compile(r'\s*\(\d+\)\s*$')


def _strip_disambig(name: str) -> str:
    """Remove a Discogs disambiguation suffix like ' (2)' from an artist name."""
    return _DISAMBIG_RE.sub("", name).strip()


def wrap_text(draw, text, font, max_width, max_lines=2):
    """Wrap *text* at word boundaries into at most *max_lines* lines.

    Returns a list of 1\u2013*max_lines* strings.  The last line is truncated
    with '\u2026' if there is still overflow after filling all available lines.
    """
    if draw.textlength(text, font=font) <= max_width:
        return [text]

    words = text.split(" ")
    lines: list[str] = []
    current: list[str] = []

    for word in words:
        probe = " ".join(current + [word])
        if draw.textlength(probe, font=font) <= max_width:
            current.append(word)
        else:
            if current:
                lines.append(" ".join(current))
            else:
                # A single word is already too wide \u2014 truncate it immediately.
                lines.append(truncate_text(draw, word, font, max_width))
            current = [word] if current else []
            if len(lines) >= max_lines:
                current = []
                break

    if current and len(lines) < max_lines:
        lines.append(" ".join(current))

    if not lines:
        return [truncate_text(draw, text, font, max_width)]

    # Always truncate the last line in case it is still too long.
    lines[-1] = truncate_text(draw, lines[-1], font, max_width)
    return lines


def hline(draw, y, x0, x1, color="black", weight=2):
    draw.line([(x0, y), (x1, y)], fill=color, width=weight)


# ── Label rendering ───────────────────────────────────────────────────────────

def _measure_wrap_extra_px(tracks_with_sides, profile, is_compilation,
                           release=None, continuation=False):
    """Return the total extra canvas px caused by text wrapping.

    Accounts for:
      * Track titles that spill onto a second line (each adds _EXTRA_LINE_H px).
      * The release title wrapping to a second line in the main header
        (adds _TITLE_WRAP_LINE_H px per extra line; skipped for continuation
        headers, which always truncate rather than wrap).
    """
    from PIL import Image, ImageDraw
    W = profile["width_px"]
    M = profile["margin_px"]
    CW = W - 2 * M
    BPM_ZONE_W = 110
    POS_W      = 90
    TITLE_MAX_W = CW - POS_W - BPM_ZONE_W - 16

    tmp = Image.new("RGB", (W, 100), "white")
    draw = ImageDraw.Draw(tmp)

    extra = 0

    # Release title wrapping (main header only).
    if release is not None and not continuation:
        title_raw = release.getTitle()
        f_t = _font_for("regular", 54, title_raw)
        title_lines = wrap_text(draw, title_raw, f_t, CW)
        extra += (len(title_lines) - 1) * _TITLE_WRAP_LINE_H

    # Track title wrapping.
    for _side, _idx, track in tracks_with_sides:
        if is_compilation:
            ts = (f"{_strip_disambig(track.getArtist())} – "
                  f"{track.getTitle(synthesise=False)}")
        else:
            ts = track.getTitle(synthesise=False)
        if not isinstance(ts, str):
            continue   # mock/stub track — skip wrapping measurement
        f_tr = _font_for("regular", 38, ts)
        dur = track.getDuration()
        dur_suffix = f" ({dur})" if isinstance(dur, str) and dur else ""
        lines = wrap_text(draw, ts + dur_suffix, f_tr, TITLE_MAX_W)
        extra += (len(lines) - 1) * _EXTRA_LINE_H

    return extra


def _continuous_height(tracks_with_sides, profile, continuation=False,
                       disc_info=None, extra_px=0):
    """Calculate canvas height for a continuous-feed label.

    Uses the same layout constants as render_label so the two stay in sync.
    Raises ValueError if the result would exceed MAX_CONTINUOUS_PX (12").
    """
    M           = profile["margin_px"]
    notes_lines = profile.get("notes_lines", 3)

    header_h = _HDR_H["continuation" if continuation else "normal"]
    if disc_info:
        header_h += _HDR_H["disc_extra"]

    sides_seen = []
    for entry in tracks_with_sides:
        side = entry[0]
        if not sides_seen or sides_seen[-1] != side:
            sides_seen.append(side)
    tracks_h = len(sides_seen) * _SIDE_HDR_H + len(tracks_with_sides) * _TRACK_ROW_H

    # notes divider (28) + content area: the larger of the QR code or N ruled lines.
    # QR code is placed flush at the start of the notes content, so we need at least
    # _QR_SIZE px.  (The phantom "NOTES:" header that used to pad this out is gone.)
    notes_h = 28 + max(_QR_SIZE, notes_lines * _LINE_SPACING)

    height = 2 * M + header_h + tracks_h + notes_h + extra_px
    if height > MAX_CONTINUOUS_PX:
        raise ValueError(
            f"Label would be {height/300:.2f}\" tall — exceeds the 12\" sleeve limit.\n"
            f"Use --split to print one label per disc."
        )
    return height


def render_label(release, tracks_with_sides, profile,
                 is_compilation, continuation=False, disc_info=None,
                 height_px=None, notes_lines=None, bpms=None):
    """Render and return a single PIL Image for one label.

    Args:
        release:           DiscogsRelease instance
        tracks_with_sides: [(side_letter, global_idx, DiscogsTrack), …]
        profile:           label size profile dict
        is_compilation:    show per-track artists when True
        continuation:      compact header for overflow continuation labels
        disc_info:         (disc_num, total_discs) for --split mode, else None
        height_px:         override canvas height (continuous labels only)
        notes_lines:       fixed note line count; None = fill remaining space
        bpms:              {global_track_idx: bpm_int} from BeatportMatcher,
                           or None/empty to show blank write zones for all tracks
    """
    W  = profile["width_px"]
    H  = height_px if height_px is not None else profile["height_px"]
    M  = profile["margin_px"]
    CW = W - 2 * M   # usable content width

    img  = Image.new("RGB", (W, H), "white")
    draw = ImageDraw.Draw(img)

    # Fonts (sizes in points; 1pt ≈ 4.17px at 300 DPI)
    f_artist    = make_font("bold",      54)   # ~225px cap height
    f_title     = make_font("regular",   54)
    f_meta      = make_font("regular",   32)
    f_side_hdr  = make_font("bold",      28)
    f_pos       = make_font("bold",      38)
    f_track     = make_font("regular",   38)
    f_notes_hdr = make_font("bold",      28)

    BPM_ZONE_W  = 110                         # right-side blank area for handwritten BPM
    POS_W       = 90                          # position column width
    TITLE_MAX_W = CW - POS_W - BPM_ZONE_W - 16

    # Continuous labels auto-size their canvas; die-cut labels have a fixed canvas.
    # Wrapping is only enabled for continuous labels — die-cut labels truncate instead,
    # because their canvas cannot grow to accommodate extra line height.
    is_continuous = profile.get("feed") == "continuous"

    x0 = M
    x1 = W - M
    y  = M

    def hl(y_pos, color="black", weight=2):
        hline(draw, y_pos, x0, x1, color=color, weight=weight)

    # ── Header ───────────────────────────────────────────────────────────────

    if continuation:
        # Minimal header: artist — title  (continued)
        hdr = f"{_strip_disambig(release.getArtist()).upper()} \u2014 {release.getTitle()}  (continued)"
        f_hdr = _font_for("regular", 32, hdr)
        draw.text((M, y), truncate_text(draw, hdr, f_hdr, CW), font=f_hdr, fill="black")
        y += 46
    else:
        # Artist (large bold caps) — strip Discogs "(N)" disambiguation suffixes.
        artist_str = truncate_text(
            draw, _strip_disambig(release.getArtist()).upper(), f_artist, CW
        )
        f_artist_r = _font_for("bold", 54, artist_str)
        draw.text((M, y), artist_str, font=f_artist_r, fill="black")
        y += 70

        # Release title — wrap to a second line if it doesn't fit on one.
        title_raw   = release.getTitle()
        f_title_r   = _font_for("regular", 54, title_raw)
        title_lines = wrap_text(draw, title_raw, f_title_r, CW)
        for i, line in enumerate(title_lines):
            draw.text((M, y), line, font=f_title_r, fill="black")
            # 58 px between wrapped lines; 70 px after the final line (original spacing).
            y += 58 if i < len(title_lines) - 1 else 70

        # Disc indicator for --split labels (immediately below title)
        if disc_info:
            disc_num, total_discs = disc_info
            draw.text((M, y), f"Disc {disc_num} of {total_discs}", font=f_meta, fill="#555555")
            y += 40

        y += 10
        hl(y); y += 18

        # Label [catno]                          Year  Country
        label_meta = f"{release.getLabel()}  [{release.getCatno()}]"
        year_cc    = f"{release.getLabelYear()}  {release.getCountry()}"
        ycc_w = draw.textlength(year_cc, font=f_meta)
        label_meta = truncate_text(draw, label_meta, f_meta, CW - ycc_w - 24)
        draw.text((M, y), label_meta, font=f_meta, fill="black")
        draw.text((W - M - ycc_w, y), year_cc, font=f_meta, fill="black")
        y += 46

        # Genre / styles                                        [rXXXXXXXX]
        rid_str = f"[r{release.getId()}]"
        rid_w   = draw.textlength(rid_str, font=f_meta)
        genre_str = truncate_text(draw, release.getGenre(), f_meta, CW - rid_w - 16)
        draw.text((M, y), genre_str, font=f_meta, fill="black")
        draw.text((W - M - rid_w, y), rid_str, font=f_meta, fill="#777777")
        y += 46

    y += 8
    hl(y); y += 18

    # ── Track listing ─────────────────────────────────────────────────────────

    current_side = object()   # sentinel — guaranteed != any real side string
    bpms = bpms or {}

    f_bpm = make_font("bold", 34)   # slightly smaller than track font for BPM values

    # Pre-compute track text height so we can bottom-align it with the BPM line
    _track_text_h = f_track.getbbox("Ag")[3]

    for side, track_idx, track in tracks_with_sides:

        # Side header when the side changes
        if side != current_side:
            current_side = side
            side_label = f"Side {side}" if side else "Tracks"
            draw.text((M, y), side_label, font=f_side_hdr, fill="black")
            y += _SIDE_HDR_H - 10
            hl(y, color="#AAAAAA", weight=1)
            y += 10

        pos = track["position"]

        # Title: "Artist – Title" on compilations, plain title otherwise.
        # synthesise=False keeps untitled tracks as-is rather than generating
        # the "Release Title Position" form that dt_process uses.
        # Strip Discogs "(N)" disambiguation suffixes from artist names.
        if is_compilation:
            track_str = f"{_strip_disambig(track.getArtist())} \u2013 {track.getTitle(synthesise=False)}"
        else:
            track_str = track.getTitle(synthesise=False)

        # Pick a CJK-capable font if the track title requires it.
        f_track_r = _font_for("regular", 38, track_str)

        # Duration suffix — prefer Discogs duration; fall back to Beatport length_ms.
        dur = track.getDuration()
        if not dur:
            _ti = bpms.get(track_idx) or {}
            _ms = _ti.get("duration_ms")
            if _ms:
                _s  = _ms // 1000
                dur = f"{_s // 60}:{_s % 60:02d}"
        dur_suffix = f" ({dur})" if dur else ""

        # Continuous labels: wrap to at most 2 lines (canvas grows to fit).
        # Die-cut labels: truncate only — canvas height is fixed and cannot grow.
        full_track_str = track_str + dur_suffix
        if is_continuous:
            title_lines = wrap_text(draw, full_track_str, f_track_r, TITLE_MAX_W)
        else:
            title_lines = [truncate_text(draw, full_track_str, f_track_r, TITLE_MAX_W)]

        row_h      = _TRACK_ROW_H + (len(title_lines) - 1) * _EXTRA_LINE_H
        bpm_line_y = y + row_h - 18
        # text_y aligns the *first* title line (and the position number) with the
        # bottom-anchor point, leaving room below for any extra wrapped lines.
        text_y = bpm_line_y - _track_text_h - (len(title_lines) - 1) * _EXTRA_LINE_H

        draw.text((M, text_y), pos, font=f_pos, fill="black")
        for line_i, line in enumerate(title_lines):
            draw.text((M + POS_W, text_y + line_i * _EXTRA_LINE_H),
                      line, font=f_track_r, fill="black")

        # BPM zone: print value if known, otherwise leave a blank write zone.
        _track_info = bpms.get(track_idx) or {}
        known_bpm   = _track_info.get("bpm")
        if known_bpm:
            bpm_str = str(known_bpm)
            bpm_w = draw.textlength(bpm_str, font=f_bpm)
            bpm_x = W - M - (BPM_ZONE_W + bpm_w) // 2  # centre in zone
            draw.text((bpm_x, text_y), bpm_str, font=f_bpm, fill="#333333")
            # Faint underline to show the write zone even with a printed value
            hline(draw, bpm_line_y, W - M - BPM_ZONE_W, W - M, color="#BBBBBB", weight=1)
        else:
            hline(draw, bpm_line_y, W - M - BPM_ZONE_W, W - M, color="#888888", weight=3)

        y += row_h

    # ── Notes section ─────────────────────────────────────────────────────────

    y += 10
    hl(y); y += 18

    # QR code sits in the bottom-left of the notes area.
    # Ruled lines that fall within the QR zone start to the right of it.
    qr_left = M

    # Continuous labels: pin QR immediately after the notes divider so that any
    # measurement error in _continuous_height() cannot push it into the track area.
    # Die-cut labels: keep the traditional bottom-corner placement but clamp upward
    # if tracks happen to overflow the fixed canvas.
    if notes_lines is not None:
        qr_top = y          # continuous — flush with start of notes content
    else:
        qr_top = max(H - M - _QR_SIZE, y)   # die-cut — bottom-aligned, no overlap

    def _hl_notes(line_y):
        x_left = qr_left + _QR_SIZE + 8 if line_y >= qr_top else M
        hline(draw, line_y, x_left, W - M, color="#DDDDDD", weight=1)

    if notes_lines is not None:
        # Continuous labels: fixed number of ruled lines (all within QR zone)
        for _ in range(notes_lines):
            y += _LINE_SPACING
            _hl_notes(y)
    else:
        # Die-cut labels: fill remaining space
        while y + _LINE_SPACING < H - M:
            y += _LINE_SPACING
            _hl_notes(y)

    # Generate QR code linking to the Discogs release page
    qr = qrcode.QRCode(
        error_correction=qrcode.constants.ERROR_CORRECT_L,
        box_size=6,
        border=1,
    )
    qr.add_data(f"https://discogs.com/release/{release.getId()}")
    qr.make(fit=True)
    qr_img = qr.make_image(fill_color="black", back_color="white").convert("RGB")
    qr_img = qr_img.resize((_QR_SIZE, _QR_SIZE), Image.NEAREST)
    img.paste(qr_img, (qr_left, qr_top))

    return img


def _chunk_continuous(all_tracks, profile, is_compilation=False):
    """Pack tracks greedily onto continuous labels up to MAX_LABEL_HEIGHT_PX.

    Returns a list of track-chunks.  The first chunk uses the normal (tall)
    header; subsequent chunks use the compact continuation header — so their
    heights are calculated accordingly.
    """
    chunks    = []
    remaining = list(all_tracks)

    while remaining:
        continuation = bool(chunks)

        # Check whether all remaining tracks fit on this label.
        try:
            _ex = _measure_wrap_extra_px(remaining, profile, is_compilation,
                                         continuation=continuation)
            h = _continuous_height(remaining, profile, continuation=continuation,
                                   extra_px=_ex)
            fits_all = h <= MAX_LABEL_HEIGHT_PX
        except ValueError:
            fits_all = False   # exceeds 12" hard limit

        if fits_all:
            chunks.append(remaining)
            break

        # Binary search for the largest prefix that fits.
        lo, hi = 1, len(remaining) - 1
        while lo < hi:
            mid = (lo + hi + 1) // 2
            try:
                _ex = _measure_wrap_extra_px(remaining[:mid], profile,
                                             is_compilation,
                                             continuation=continuation)
                h = _continuous_height(remaining[:mid], profile,
                                       continuation=continuation, extra_px=_ex)
                if h <= MAX_LABEL_HEIGHT_PX:
                    lo = mid
                else:
                    hi = mid - 1
            except ValueError:
                hi = mid - 1

        take = max(lo, 1)   # always advance by at least one track
        chunks.append(remaining[:take])
        remaining = remaining[take:]

    return chunks


def _render_kwargs(tracks, profile, continuation=False, disc_info=None,
                   release=None, is_compilation=False):
    """Return extra kwargs for render_label based on feed type."""
    if profile.get("feed") == "continuous":
        extra = _measure_wrap_extra_px(tracks, profile, is_compilation,
                                       release=release,
                                       continuation=continuation)
        h = _continuous_height(tracks, profile, continuation=continuation,
                               disc_info=disc_info, extra_px=extra)
        return {"height_px": h, "notes_lines": profile.get("notes_lines", 3)}
    return {}


def render_labels_for_release(release, args, profile, bpms=None):
    """Return [(filename_suffix, PIL.Image), …] for all labels to produce.

    Args:
        bpms: {global_track_idx: bpm_int} from BeatportMatcher, or None.
    """
    is_compilation = release.isCompilation()
    discs          = group_tracks_by_disc(release)
    max_tracks     = profile["max_tracks"]
    labels         = []
    bpms           = bpms or {}

    if args.split:
        total_discs = len(discs)
        for disc_num in sorted(discs):
            disc_tracks = []
            for side in sorted(discs[disc_num]):
                for idx, track in discs[disc_num][side]:
                    disc_tracks.append((side, idx, track))
            kw = _render_kwargs(disc_tracks, profile,
                                disc_info=(disc_num, total_discs),
                                release=release, is_compilation=is_compilation)
            img = render_label(release, disc_tracks, profile,
                               is_compilation,
                               disc_info=(disc_num, total_discs),
                               bpms=bpms, **kw)
            labels.append((f"disc{disc_num}", img))

    else:
        # Chunk all tracks into primary + continuation labels.
        # Continuous labels: pack by height up to 11.5".
        # Die-cut labels: pack by max_tracks (fixed canvas size).
        all_tracks = flatten_discs(discs)
        if profile.get("feed") == "continuous":
            chunks = _chunk_continuous(all_tracks, profile, is_compilation=is_compilation)
        else:
            chunks = [all_tracks[i:i + max_tracks]
                      for i in range(0, len(all_tracks), max_tracks)]
        for idx, chunk in enumerate(chunks):
            suffix = "label" if idx == 0 else f"cont{idx}"
            kw = _render_kwargs(chunk, profile, continuation=(idx > 0),
                               release=release, is_compilation=is_compilation)
            img = render_label(release, chunk, profile,
                               is_compilation, continuation=(idx > 0),
                               bpms=bpms, **kw)
            labels.append((suffix, img))

    return labels


# ── Printing ──────────────────────────────────────────────────────────────────

def print_label(img, printer_url, model, profile, retries=3, retry_delay=5):
    """Send a rendered label image to the Brother printer over TCP/WiFi.

    Retries up to `retries` times on network errors, waiting `retry_delay`
    seconds between attempts.  Raises RuntimeError on final failure.
    """
    from brother_ql.conversion import convert
    from brother_ql.backends.helpers import send
    from brother_ql.raster import BrotherQLRaster

    qlr = BrotherQLRaster(model)
    instructions = convert(
        qlr,
        images=[img],
        label=profile["brother_ql_id"],
        rotate="0",
        threshold=70,
        dither=False,
        compress=False,
        red=False,
        dpi_600=False,
        cut=True,
    )

    for attempt in range(1, retries + 1):
        try:
            send(
                instructions=instructions,
                printer_identifier=printer_url,
                backend_identifier="network",
                blocking=True,
            )
            return
        except (TimeoutError, OSError) as e:
            if attempt < retries:
                print(f"\n  Network error ({e}); retrying in {retry_delay}s "
                      f"(attempt {attempt}/{retries})…", flush=True)
                time.sleep(retry_delay)
            else:
                raise RuntimeError(
                    f"Printer unreachable after {retries} attempts: {e}\n"
                    "  Check that the printer is on, not in an error state "
                    "(solid green LED), and reachable on the network."
                ) from e


# ── CLI ───────────────────────────────────────────────────────────────────────

def parse_release_id(value):
    """Accept a plain integer or the bracketed [r<id>] format used by dt_process."""
    m = re.fullmatch(r'\[r(\d+)\]', value.strip())
    if m:
        return int(m.group(1))
    try:
        return int(value)
    except ValueError:
        raise argparse.ArgumentTypeError(
            f"invalid release ID {value!r} — expected an integer or [r<id>]"
        )


_DISCOGS_URL_RE = re.compile(r'discogs\.com/release/(\d+)')

def read_id_file(path):
    """Parse a text file and extract Discogs release IDs.

    Strategy: if the file contains any Discogs URLs, extract IDs only from
    those URLs and ignore everything else (handles mixed-content files with
    annotations, sequence numbers, etc.).  If the file contains no URLs at
    all, every non-blank non-comment line is parsed as a release ID (plain
    integer or [rXXXXXXXX] form), with a warning on unrecognised lines.

    Blank lines and lines beginning with # are always ignored.
    Returns a list of (line_number, raw_value, parsed_id) tuples.
    """
    with open(path) as f:
        lines = [(lineno, raw.strip())
                 for lineno, raw in enumerate(f, 1)
                 if raw.strip() and not raw.strip().startswith("#")]

    # First pass: collect any URL matches
    url_matches = [(lineno, line, int(m.group(1)))
                   for lineno, line in lines
                   for m in [_DISCOGS_URL_RE.search(line)] if m]

    if url_matches:
        return url_matches  # URL mode: ignore everything that isn't a URL

    # Plain-ID mode: parse every line as a release ID
    ids = []
    for lineno, line in lines:
        try:
            ids.append((lineno, line, parse_release_id(line)))
        except argparse.ArgumentTypeError as e:
            print(f"  {path}:{lineno}: skipping {line!r} — {e}", file=sys.stderr)
    return ids


def _lookup_bpms(release, no_bpm=False):
    """Try Beatport BPM lookup.  Returns {} on any failure or if disabled.

    Failures are non-fatal: the label is printed without BPM data instead.
    Import errors are handled separately so a missing beatport.py or absent
    'requests' package doesn't produce a confusing traceback.
    """
    if no_bpm:
        return {}

    try:
        import beatport
    except ImportError as e:
        log.debug("beatport module not importable: %s", e)
        return {}

    try:
        matcher = beatport.BeatportMatcher()
        bpms = matcher.find_bpms(release)
        if bpms:
            print(f"  Beatport: matched {len(bpms)} track(s) (BPM/duration)")
        else:
            print("  Beatport: no BPMs found")
        return bpms
    except beatport.BeatportError as e:
        print(f"  Beatport: skipping BPM lookup — {e}", file=sys.stderr)
        return {}
    except Exception as e:
        print(f"  Beatport: unexpected error — {e}", file=sys.stderr)
        return {}


def process_release(rid, args, profile, printer_url, model):
    """Fetch, render, and output labels for one release ID.

    Returns True on success, False on error.
    """
    print(f"Fetching Discogs release {rid}\u2026")
    try:
        release = client_interface.DiscogsRelease(rid)
    except Exception as e:
        print(f"  Error fetching release {rid}: {e}", file=sys.stderr)
        return False
    print(f"  {release}")

    bpms = _lookup_bpms(release, no_bpm=getattr(args, "no_bpm", False))

    try:
        labels = render_labels_for_release(release, args, profile, bpms=bpms)
    except ValueError as e:
        print(f"  Error rendering release {rid}: {e}", file=sys.stderr)
        return False
    if args.split and getattr(args, "discs", None):
        want = {f"disc{d}" for d in args.discs}
        all_suffixes = [s for s, _ in labels]
        labels = [(s, img) for s, img in labels if s in want]
        if not labels:
            print(f"  No labels match --discs {args.discs}; "
                  f"available: {all_suffixes}", file=sys.stderr)
            return False

    print(f"  {len(labels)} label(s) to produce")

    inter_label_delay = getattr(args, "delay", 2)

    for i, (suffix, img) in enumerate(labels):
        if args.preview:
            os.makedirs(args.output, exist_ok=True)
            fname = os.path.join(args.output, f"{rid}_{suffix}.png")
            img.save(fname, dpi=(300, 300))
            print(f"  Saved: {fname}")
        else:
            if i > 0 and inter_label_delay > 0:
                time.sleep(inter_label_delay)
            print(f"  Printing {suffix}\u2026", end=" ", flush=True)
            try:
                print_label(img, printer_url, model, profile)
            except RuntimeError as e:
                print(f"\n  {e}", file=sys.stderr)
                return False
            print("done.")
    return True


def main():
    parser = argparse.ArgumentParser(
        description="Print a Discogs release stat-block label for a vinyl sleeve.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("release_id", type=parse_release_id, nargs="?",
                        help="Discogs release ID — plain integer or [r12345678] form")
    parser.add_argument("-f", "--file", metavar="FILE",
                        help="Text file with one release ID per line (batch mode)")
    parser.add_argument("-p", "--preview", action="store_true",
                        help="Save label(s) as PNG instead of sending to printer")
    parser.add_argument("-s", "--split", action="store_true",
                        help="One full stat block per disc (for boxed sets stored separately)")
    parser.add_argument("-o", "--output", default=".",
                        help="Output directory for preview PNGs (default: current dir)")
    parser.add_argument("--printer", metavar="URL",
                        help="Printer URL e.g. tcp://192.168.1.50:9100  (saved for reuse)")
    parser.add_argument("--model", metavar="MODEL",
                        help=f"Printer model identifier (default: {DEFAULT_MODEL}, saved)")
    parser.add_argument("--label-profile", metavar="PROFILE",
                        choices=list(LABEL_PROFILES.keys()),
                        help=f"Label size profile (default: {DEFAULT_PROFILE}, saved)")
    parser.add_argument("--list-profiles", action="store_true",
                        help="List available label profiles and exit")
    parser.add_argument("--no-bpm", action="store_true",
                        help="Skip Beatport BPM lookup (faster, blank write zones only)")
    parser.add_argument("--discs", metavar="N", type=int, nargs="+",
                        help="With --split: only print these disc numbers (e.g. --discs 3)")
    parser.add_argument("--delay", metavar="SECS", type=float, default=2.0,
                        help="Seconds to wait between labels when printing multiple (default: 2)")
    args = parser.parse_args()

    if args.list_profiles:
        print("Available label profiles:")
        for name, p in LABEL_PROFILES.items():
            print(f"  {name:12s}  {p['description']}")
            if p.get("feed") == "continuous":
                size_str = f"{p['width_px']}px wide, continuous (auto-height)"
            else:
                size_str = f"{p['width_px']}×{p['height_px']}px"
            print(f"              {size_str}, max {p['max_tracks']} tracks, "
                  f"brother_ql id: {p['brother_ql_id']}")
        sys.exit(0)

    # Validate: need exactly one of release_id or --file
    if args.release_id is None and not args.file:
        parser.error("provide a release ID or use -f/--file for batch input")
    if args.release_id is not None and args.file:
        parser.error("release_id and -f/--file are mutually exclusive")

    # Load saved config, apply any CLI overrides, persist if changed
    config  = load_config()
    changed = False
    if args.printer:
        config["printer"] = args.printer;      changed = True
    if args.model:
        config["model"]   = args.model;        changed = True
    if args.label_profile:
        config["profile"] = args.label_profile; changed = True
    if changed:
        save_config(config)

    printer_url  = config.get("printer")
    model        = config.get("model",   DEFAULT_MODEL)
    profile_name = config.get("profile", DEFAULT_PROFILE)
    profile      = LABEL_PROFILES[profile_name]

    if not args.preview and not printer_url:
        print("Error: no printer configured.", file=sys.stderr)
        print("  Use --printer tcp://IP:9100 to set your printer, or", file=sys.stderr)
        print("  Use --preview to render PNGs without printing.", file=sys.stderr)
        sys.exit(1)

    # Build list of release IDs to process
    if args.file:
        entries = read_id_file(args.file)
        if not entries:
            print("No valid release IDs found in file.", file=sys.stderr)
            sys.exit(1)
        release_ids = [rid for _, _, rid in entries]
        print(f"Batch: {len(release_ids)} release(s) from {args.file}")
    else:
        release_ids = [args.release_id]

    # Process each release
    errors = 0
    for rid in release_ids:
        if not process_release(rid, args, profile, printer_url, model):
            errors += 1

    if errors:
        print(f"\n{errors} release(s) failed.", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
