# ── System prompt ──────────────────────────────────────────────────────────────

SYSTEM_PROMPT = """\
You are a vinyl record identification assistant integrated into a home music system.

The user will describe a record from their collection — possibly vaguely, using
informal names, cover art descriptions, or partial information. Your job is to
identify the specific Discogs release they mean, then call select_release with its ID.

Use the search_discogs tool to search. Call it as many times as needed.

Guidelines
----------
* Draw on your musical knowledge to interpret descriptions:
  - "the blue one" by Miles Davis = "Kind of Blue" (Columbia, 1959)
  - colour descriptions often refer to iconic cover art
  - "the one with the triangle" = Pink Floyd "Dark Side of the Moon"
* Discogs has thousands of pressings of each album. Search broadly first
  (artist + album title), examine the results, then narrow to the likely
  pressing by label, year, or catalog number if the user mentioned any details.
* Try several query formulations if the first doesn't work.
* The user owns a physical vinyl record, so prefer results with format=Vinyl or LP.
* Only call select_release when you are confident — if multiple pressings match
  and you cannot distinguish, pick the most common/canonical one and say so.
* If you genuinely cannot find a match after several searches, respond in plain
  text explaining what you tried and asking the user for more detail.
* Do NOT speculate a release_id — only use IDs that appeared in search results.
"""


# ── Discogs search tool implementation ────────────────────────────────────────

def _tool_search_discogs(
    q: str | None = None,
    artist: str | None = None,
    title: str | None = None,
    label: str | None = None,
    year: str | None = None,
    catno: str | None = None,
    format: str | None = None,
) -> dict:
    """Execute a Discogs search and return a JSON-serialisable result dict."""
    dc = client_interface.get_client_instance()

    kwargs: dict = {"type": "release"}
    if q:       kwargs["q"]            = q
    if artist:  kwargs["artist"]       = artist
    if title:   kwargs["release_title"] = title   # Discogs API field name
    if label:   kwargs["label"]        = label
    if year:    kwargs["year"]         = str(year)
    if catno:   kwargs["catno"]        = catno
    if format:  kwargs["format"]       = format

    try:
        results = dc.search(**kwargs)
        results.per_page = RESULTS_PER_SEARCH
        page = results.page(1)
    except Exception as e:
        log.warning("Discogs search error: %s", e)
        return {"error": str(e), "results": [], "count": 0}

    formatted = []
    for item in list(page)[:RESULTS_PER_SEARCH]:
        d = getattr(item, "data", {}) or {}
        # Discogs returns "Artist - Title" in the title field for releases
        raw_title = d.get("title", "")
        if " - " in raw_title:
            item_artist, item_title = raw_title.split(" - ", 1)
        else:
            item_artist, item_title = "", raw_title

        uri = d.get("uri", "")
        formatted.append({
            "id":      d.get("id"),
            "artist":  item_artist.strip(),
            "title":   item_title.strip(),
            "label":   d.get("label", []),
            "catno":   d.get("catno", ""),
            "year":    d.get("year", ""),
            "country": d.get("country", ""),
            "format":  d.get("format", []),
            "url":     f"https://www.discogs.com{uri}" if uri else None,
        })

    return {
        "count":   getattr(results, "count", len(formatted)),
        "results": formatted,
    }


def _fmt_search_args(args: dict) -> str:
    """One-line summary of search parameters for progress display."""
    parts = []
    for k in ("q", "artist", "title", "label", "year", "catno", "format"):
        if args.get(k):
            parts.append(f"{k}={args[k]!r}")
    return ", ".join(parts) or "(no parameters)"


# ── Strip thinking tags (Qwen3 / reasoning models) ────────────────────────────

_THINK_RE = re.compile(r"<think>.*?</think>", re.DOTALL)


def _strip_think(text: str) -> str:
    return _THINK_RE.sub("", text).strip()


def _extract_think(text: str) -> str | None:
    m = _THINK_RE.search(text)
    return m.group(0)[7:-8].strip() if m else None  # strip <think>…</think>


# ── Abstract LLM backend ──────────────────────────────────────────────────────

class LLMBackend(ABC):
    """Abstract base for LLM backends used by dt_find.

    Subclasses implement the model-specific agent loop and availability check.
    Two concrete backends are provided:
      - LocalLLMBackend  — OpenAI-compatible API (MLX, llama.cpp, vLLM, …)
      - AnthropicBackend — Anthropic Claude API (Haiku recommended)
    """

    @property
    @abstractmethod
    def name(self) -> str:
        """Human-readable backend identifier (shown in the UI and on startup)."""

    @abstractmethod
    def check_available(self) -> tuple[bool, str]:
        """Return (ok, error_message).

        ok=True means the backend is configured and (best-effort) reachable.
        error_message is empty when ok=True.
        """

    @abstractmethod
    def run_agent(
        self,
        description: str,
        verbose: bool = False,
    ) -> tuple[int | None, str]:
        """Run the tool-calling agent loop.

        Returns (release_id, reasoning) where release_id is a Discogs release
        ID, or (None, '') if the agent could not identify the record.
        """


# ── Local OpenAI-compatible backend ───────────────────────────────────────────

class LocalLLMBackend(LLMBackend):
    """OpenAI-compatible local LLM backend (MLX, llama.cpp, vLLM, etc.).

    The LLM must support function / tool calling.  Reasoning-model <think>
    blocks are stripped from responses before display.
    """

    def __init__(self, llm_url: str, llm_model: str) -> None:
        self._url   = llm_url
        self._model = llm_model

    @property
    def name(self) -> str:
        return f"Local LLM ({self._model})"

    def check_available(self) -> tuple[bool, str]:
        if not self._url:
            return False, "no LLM URL configured"
        try:
            import requests as _req
            _req.get(f"{self._url}/models", timeout=3)
            return True, ""
        except Exception as e:
            return False, f"LLM server unreachable: {e}"

    def run_agent(
        self,
        description: str,
        verbose: bool = False,
    ) -> tuple[int | None, str]:
        try:
            from openai import OpenAI
        except ImportError:
            raise SystemExit(
                "The openai package is required: pip install openai"
            )

        client = OpenAI(base_url=self._url, api_key="not-required")

        messages: list[dict] = [
            {"role": "system", "content": SYSTEM_PROMPT},
            {"role": "user",   "content": description},
        ]

        for _turn in range(MAX_SEARCH_TURNS):
            try:
                response = client.chat.completions.create(
                    model=self._model,
                    messages=messages,
                    tools=TOOLS,
                    tool_choice="auto",
                )
            except Exception as e:
                print(f"\nLLM error: {e}", file=sys.stderr)
                return None, ""

            msg     = response.choices[0].message
            content = msg.content or ""
            visible = _strip_think(content)

            if verbose:
                thinking = _extract_think(content)
                if thinking:
                    print("\033[2m[thinking…]\033[0m", end=" ", flush=True)

            # Build the assistant entry for message history.
            # The openai SDK returns a ChatCompletionMessage; convert to plain
            # dict so we can append custom fields without type issues.
            asst_entry: dict = {"role": "assistant", "content": content}
            if msg.tool_calls:
                asst_entry["tool_calls"] = [
                    {
                        "id":       tc.id,
                        "type":     "function",
                        "function": {
                            "name":      tc.function.name,
                            "arguments": tc.function.arguments,
                        },
                    }
                    for tc in msg.tool_calls
                ]
            messages.append(asst_entry)

            # No tool calls → LLM gave a final text response
            if not msg.tool_calls:
                if visible:
                    print(f"\n{visible}")
                return None, ""

            # Execute each tool call
            for tc in msg.tool_calls:
                name = tc.function.name
                try:
                    args = json.loads(tc.function.arguments or "{}")
                except json.JSONDecodeError:
                    args = {}

                if name == "select_release":
                    release_id = args.get("release_id")
                    reasoning  = args.get("reasoning", "")
                    # Acknowledge the tool call so the model can close gracefully
                    messages.append({
                        "role":         "tool",
                        "tool_call_id": tc.id,
                        "content":      json.dumps({"status": "ok"}),
                    })
                    return int(release_id), reasoning

                elif name == "search_discogs":
                    print(f"  🔍  Searching: {_fmt_search_args(args)}", flush=True)
                    result = _tool_search_discogs(**args)
                    n     = len(result.get("results", []))
                    total = result.get("count", 0)
                    print(f"      → {n} result(s) returned  ({total} total on Discogs)")
                    messages.append({
                        "role":         "tool",
                        "tool_call_id": tc.id,
                        "content":      json.dumps(result),
                    })

                else:
                    # Unknown tool — return an error so the model can recover
                    messages.append({
                        "role":         "tool",
                        "tool_call_id": tc.id,
                        "content":      json.dumps({"error": f"Unknown tool: {name}"}),
                    })

        print("\nReached search limit without a confident match.", file=sys.stderr)
        return None, ""


# ── Anthropic Claude API backend ──────────────────────────────────────────────

class AnthropicBackend(LLMBackend):
    """Anthropic Claude API backend using native tool use.

    Uses the same Anthropic API key as the Beatport AnthropicMatcher
    (beatport_auth.json → "anthropic_api_key", or ANTHROPIC_API_KEY env var).
    Recommended model: claude-haiku-4-5-20251001 (fast and cheap).
    """

    DEFAULT_MODEL      = "claude-haiku-4-5-20251001"
    _API_URL           = "https://api.anthropic.com/v1/messages"
    _ANTHROPIC_VERSION = "2023-06-01"

    def __init__(self, model: str | None = None) -> None:
        self._model = model or self.DEFAULT_MODEL

    @property
    def name(self) -> str:
        return f"Anthropic ({self._model})"

    def _get_api_key(self) -> str | None:
        """Read API key from beatport_auth.json or ANTHROPIC_API_KEY env var."""
        try:
            auth_path = util.userfile("beatport_auth.json")
            if os.path.exists(auth_path):
                with open(auth_path) as f:
                    data = json.load(f)
                key = data.get("anthropic_api_key")
                if key:
                    return key
        except Exception:
            pass
        return os.environ.get("ANTHROPIC_API_KEY")

    def check_available(self) -> tuple[bool, str]:
        key = self._get_api_key()
        if not key:
            return False, "no Anthropic API key configured"
        return True, ""

    def run_agent(
        self,
        description: str,
        verbose: bool = False,
    ) -> tuple[int | None, str]:
        try:
            import requests
        except ImportError:
            raise SystemExit("The requests package is required: pip install requests")

        api_key = self._get_api_key()
        if not api_key:
            print("Anthropic API key not configured.", file=sys.stderr)
            return None, ""

        headers = {
            "x-api-key":         api_key,
            "anthropic-version": self._ANTHROPIC_VERSION,
            "content-type":      "application/json",
        }

        # Anthropic uses system as a top-level field, not a message
        messages: list[dict] = [
            {"role": "user", "content": description},
        ]

        for _turn in range(MAX_SEARCH_TURNS):
            payload = {
                "model":      self._model,
                "max_tokens": 1024,
                "system":     SYSTEM_PROMPT,
                "tools":      ANTHROPIC_TOOLS,
                "messages":   messages,
            }
            try:
                r = requests.post(
                    self._API_URL, headers=headers, json=payload, timeout=60
                )
                r.raise_for_status()
                data = r.json()
            except Exception as e:
                print(f"\nAnthropic API error: {e}", file=sys.stderr)
                return None, ""

            content_blocks: list[dict] = data.get("content", [])

            # Append the full assistant turn (text + tool_use blocks intact)
            messages.append({"role": "assistant", "content": content_blocks})

            tool_uses   = [b for b in content_blocks if b.get("type") == "tool_use"]
            text_blocks = [b for b in content_blocks if b.get("type") == "text"]

            if not tool_uses:
                if text_blocks:
                    print(f"\n{''.join(b.get('text', '') for b in text_blocks)}")
                return None, ""

            # Process tool calls; collect results for the next user turn
            tool_results: list[dict] = []
            selected: tuple[int, str] | None = None

            for tc in tool_uses:
                tc_id = tc.get("id", "")
                name  = tc.get("name", "")
                inp   = tc.get("input", {})

                if name == "select_release":
                    release_id = inp.get("release_id")
                    reasoning  = inp.get("reasoning", "")
                    tool_results.append({
                        "type":        "tool_result",
                        "tool_use_id": tc_id,
                        "content":     json.dumps({"status": "ok"}),
                    })
                    selected = (int(release_id), reasoning)

                elif name == "search_discogs":
                    print(f"  🔍  Searching: {_fmt_search_args(inp)}", flush=True)
                    result = _tool_search_discogs(**inp)
                    n     = len(result.get("results", []))
                    total = result.get("count", 0)
                    print(f"      → {n} result(s) returned  ({total} total on Discogs)")
                    tool_results.append({
                        "type":        "tool_result",
                        "tool_use_id": tc_id,
                        "content":     json.dumps(result),
                    })

                else:
                    tool_results.append({
                        "type":        "tool_result",
                        "tool_use_id": tc_id,
                        "content":     json.dumps({"error": f"Unknown tool: {name}"}),
                    })

            # Tool results must be sent back as a user message
            messages.append({"role": "user", "content": tool_results})

            if selected is not None:
                return selected

        print("\nReached search limit without a confident match.", file=sys.stderr)
        return None, ""


# ── Backend factory ───────────────────────────────────────────────────────────

def create_backend(config: dict) -> LLMBackend:
    """Instantiate the appropriate LLMBackend from a find_config dict."""
    backend_name = config.get("backend", "local")
    if backend_name == "anthropic":
        model = config.get("find_anthropic_model") or None
        return AnthropicBackend(model=model)
    # Default: local OpenAI-compatible server
    url   = config.get("llm_url",   DEFAULT_LLM_URL)
    model = config.get("llm_model", DEFAULT_LLM_MODEL)
    return LocalLLMBackend(url, model)


# ── Result display + confirm ───────────────────────────────────────────────────

def show_and_confirm(
    release_id: int,
    reasoning: str,
    open_browser: bool = True,
    no_print: bool = False,
) -> bool:
    """Fetch release info, display it, open the browser, and ask the user to confirm.

    Returns True if the user wants to print the label.
    """
    print(f"\n{'─' * 60}")
    print(f"  Discogs release r{release_id}")

    # Fetch basic info to display (lightweight — uses cache if available)
    try:
        rel = client_interface.DiscogsRelease(release_id)
        print(f"  {rel.getArtist()} — {rel.getTitle()}")
        print(f"  {rel.getLabel()}  [{rel.getCatno()}]  {rel.getYear()}  {rel.getCountry()}")
        print(f"  {rel.getGenre()}")
    except Exception as e:
        log.debug("Could not fetch release detail: %s", e)
        print(f"  (could not fetch release details: {e})")

    if reasoning:
        print(f"\n  Why: {reasoning}")

    discogs_url = f"https://www.discogs.com/release/{release_id}"
    print(f"\n  {discogs_url}")
    print(f"{'─' * 60}\n")

    if open_browser:
        try:
            webbrowser.open(discogs_url)
        except Exception as e:
            log.debug("webbrowser.open failed: %s", e)

    if no_print:
        return False

    try:
        answer = input("Print label? [Y/n] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        answer = "n"

    return answer in ("", "y", "yes")


# ── Print via dt_label ─────────────────────────────────────────────────────────

def print_label(release_id: int, no_bpm: bool = False, preview: bool = False) -> None:
    """Invoke dt_label for the given Discogs release ID."""
    script = os.path.join(os.path.dirname(os.path.abspath(__file__)), "dt_label")
    cmd = [sys.executable, script, str(release_id)]
    if no_bpm:
        cmd.append("--no-bpm")
    if preview:
        cmd.extend(["--preview", "--output", "."])
    try:
        subprocess.run(cmd, check=True)
    except subprocess.CalledProcessError as e:
        print(f"dt_label exited with error {e.returncode}", file=sys.stderr)
    except FileNotFoundError:
        print(f"Could not find dt_label at {script}", file=sys.stderr)


# ── CLI ────────────────────────────────────────────────────────────────────────

def main() -> None:
    import argparse

    parser = argparse.ArgumentParser(
        description="Voice/text vinyl record finder powered by an LLM.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "description", nargs="?", metavar="TEXT",
        help="Record description as a command-line argument (skips input prompt)",
    )
    parser.add_argument(
        "--text", "-t", action="store_true",
        help="Force typed text input even if voice is available",
    )
    parser.add_argument(
        "--verbose", "-v", action="store_true",
        help="Show LLM thinking indicators and debug info",
    )
    parser.add_argument(
        "--no-browser", action="store_true",
        help="Don't open the browser (still shows the URL)",
    )
    parser.add_argument(
        "--no-print", action="store_true",
        help="Don't offer to print a label (browser + confirm only)",
    )
    parser.add_argument(
        "--no-bpm", action="store_true",
        help="Skip Beatport BPM lookup when printing",
    )
    parser.add_argument(
        "--preview", action="store_true",
        help="Save label as PNG instead of printing",
    )
    parser.add_argument(
        "--backend", metavar="BACKEND", choices=["local", "anthropic"],
        help="LLM backend: 'local' (OpenAI-compatible) or 'anthropic' (Claude API). Saved.",
    )
    parser.add_argument(
        "--wintermute", metavar="URL",
        help=f"Local LLM server base URL (default: {DEFAULT_LLM_URL}, saved)",
    )
    parser.add_argument(
        "--model", metavar="MODEL",
        help=f"Local LLM model name (default: {DEFAULT_LLM_MODEL}, saved)",
    )
    args = parser.parse_args()

    if args.verbose:
        logging.basicConfig(level=logging.DEBUG, stream=sys.stderr)

    # Load/update saved config
    config  = load_config()
    changed = False
    if args.backend:
        config["backend"]   = args.backend;  changed = True
    if args.wintermute:
        config["llm_url"]   = args.wintermute; changed = True
    if args.model:
        config["llm_model"] = args.model;      changed = True
    if changed:
        save_config(config)

    backend = create_backend(config)

    # ── Get description ───────────────────────────────────────────────────────

    description: str | None = args.description

    if not description:
        if args.text:
            description = get_description_text()
        else:
            # Try voice; fall back to typed input if voice deps missing or fail
            try:
                description = get_description_voice()
            except SystemExit as e:
                # Voice deps not installed — fall back to text silently
                print(f"(Voice unavailable: {e})\n", file=sys.stderr)
                description = get_description_text()

    if not description:
        print("No description provided. Exiting.", file=sys.stderr)
        sys.exit(1)

    print(f"\n  \u2192 Finding: \u201c{description}\u201d")
    print(f"  \u2192 LLM: {backend.name}\n")

    # ── Run agent ─────────────────────────────────────────────────────────────

    release_id, reasoning = backend.run_agent(
        description,
        verbose=args.verbose,
    )

    if release_id is None:
        print("\nCould not identify the record. Try being more specific.",
              file=sys.stderr)
        sys.exit(1)

    # ── Confirm + print ───────────────────────────────────────────────────────

    should_print = show_and_confirm(
        release_id,
        reasoning,
        open_browser=not args.no_browser,
        no_print=args.no_print,
    )

    if should_print:
        print(f"\nPrinting label for r{release_id}…")
        print_label(release_id, no_bpm=args.no_bpm, preview=args.preview)


if __name__ == "__main__":
    main()
