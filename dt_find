def load_config() -> dict:
    path = util.userfile(CONFIG_FILE)
    config: dict = {}
    if os.path.exists(path):
        with open(path) as f:
            for line in f:
                line = line.strip()
                if "=" in line and not line.startswith("#"):
                    k, v = line.split("=", 1)
                    config[k.strip()] = v.strip()
    return config


def save_config(config: dict) -> None:
    path = util.userfile(CONFIG_FILE)
    with open(path, "w") as f:
        f.write("# dt_find configuration — auto-updated\n")
        for k, v in config.items():
            f.write(f"{k}={v}\n")


# ── Voice input ────────────────────────────────────────────────────────────────

def record_until_enter(sample_rate: int = 16000) -> "numpy.ndarray | None":
    """Record from the default mic until the user presses Enter.

    Returns a 1-D int16 numpy array, or None on failure.
    Requires: sounddevice, numpy.
    """
    try:
        import sounddevice as sd
        import numpy as np
    except ImportError as e:
        raise SystemExit(
            f"Voice input requires: pip install sounddevice\nMissing: {e}"
        )

    import numpy as np  # ensure it's available in scope below
    chunks: list = []

    def _cb(indata, frames, time, status):  # noqa: ARG001
        chunks.append(indata.copy())

    print("  🎤  Listening… press Enter when done speaking.")
    with sd.InputStream(samplerate=sample_rate, channels=1, dtype="int16",
                        callback=_cb):
        input()  # block until Enter

    if not chunks:
        return None
    return np.concatenate(chunks).flatten()


def transcribe_audio(audio_array: "numpy.ndarray", sample_rate: int = 16000) -> str | None:
    """Transcribe a numpy int16 audio array using macOS on-device speech recognition.

    Requires: SpeechRecognition.
    """
    try:
        import speech_recognition as sr
    except ImportError as e:
        raise SystemExit(
            f"Transcription requires: pip install SpeechRecognition\nMissing: {e}"
        )

    r = sr.Recognizer()
    audio_data = sr.AudioData(audio_array.tobytes(), sample_rate, 2)
    print("  Transcribing…", end=" ", flush=True)
    try:
        text = r.recognize_apple(audio_data)
        print(f"\u201c{text}\u201d")
        return text
    except sr.UnknownValueError:
        print("(could not understand audio)")
        return None
    except sr.RequestError as e:
        print(f"(recognition error: {e})")
        return None


def get_description_voice() -> str | None:
    """Capture a spoken description from the microphone."""
    audio = record_until_enter()
    if audio is None or len(audio) == 0:
        print("No audio recorded.", file=sys.stderr)
        return None
    return transcribe_audio(audio)


def get_description_text(prompt: str = "Describe the record: ") -> str | None:
    try:
        text = input(prompt).strip()
        return text or None
    except (EOFError, KeyboardInterrupt):
        return None


