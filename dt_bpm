#!/usr/bin/env python3
"""dt_bpm — per-track BPM diagnostic report for a Discogs release.

For each track reports:
  • Beatport declared BPM and track duration
  • Local Essentia analysis: detected BPM, confidence, and the decision taken
  • Final (chosen) BPM

Requires the ``essentia`` Python package.

Usage
-----
    dt_bpm RELEASE_ID [options]

Options
-------
    --force      Ignore cached nomatch; force a fresh Beatport search
    --reverify   Re-download previews and re-run Essentia (ignores bpm_verified cache)
    -v/--verbose Enable debug logging to stderr
"""

from __future__ import annotations

import argparse
import logging
import os
import sys

# Ensure the project root is on sys.path regardless of cwd
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

import essentia.standard as es  # type: ignore[import-untyped]

from client_interface import DiscogsRelease, ClientException
import beatport as bp

log = logging.getLogger(__name__)


# ── Decision explanation ───────────────────────────────────────────────────────

def _explain_decision(detected: float | None, confidence: float | None) -> str:
    """Return a human-readable string explaining why a BPM was accepted or rejected."""
    if detected is None or confidence is None or (detected == 0.0 and confidence == 0.0):
        return "analysis failed → no BPM"

    if detected < bp.BPM_VERIFY_MIN or detected > bp.BPM_VERIFY_MAX:
        return (
            f"out of range [{bp.BPM_VERIFY_MIN:.0f}–{bp.BPM_VERIFY_MAX:.0f}]"
            f" → rejected"
        )

    if confidence < bp.BPM_VERIFY_MIN_CONFIDENCE:
        return (
            f"confidence {confidence:.2f} < {bp.BPM_VERIFY_MIN_CONFIDENCE:.1f}"
            f" → rejected"
        )

    return f"confidence {confidence:.2f} ≥ {bp.BPM_VERIFY_MIN_CONFIDENCE:.1f} → accepted"


# ── Duration formatting ────────────────────────────────────────────────────────

def _fmt_duration(ms: int | None) -> str:
    if ms is None:
        return "—"
    s = ms // 1000
    return f"{s // 60}:{s % 60:02d}"


# ── Per-track analysis ─────────────────────────────────────────────────────────

def _run_essentia_for_track(
    idx: int,
    entry: dict,
    cache: bp.BeatportCache,
    reverify: bool,
) -> dict:
    """Download the preview and run Essentia for one track entry.

    Returns a dict with keys: declared_bpm, detected_bpm, confidence,
    chosen_bpm, decision.  detected_bpm/confidence are None when no preview
    URL is available for this track.
    """
    declared_bpm = entry.get("bpm")
    sample_url   = entry.get("sample_url")
    bp_track_id  = entry.get("beatport_track_id")

    if sample_url is None or bp_track_id is None:
        return {
            "declared_bpm": declared_bpm,
            "detected_bpm": None,
            "confidence":   None,
            "chosen_bpm":   None,
            "decision":     "no preview available",
        }

    # Check cache first (unless --reverify)
    if not reverify:
        detail = cache.get_verified_bpm_detail(bp_track_id)
        if detail is not None:
            decision = _explain_decision(detail["detected_bpm"], detail["confidence"])
            return {
                "declared_bpm": detail["declared_bpm"],
                "detected_bpm": detail["detected_bpm"],
                "confidence":   detail["confidence"],
                "chosen_bpm":   detail["chosen_bpm"],
                "decision":     decision + "  (cached)",
            }

    # Fresh analysis — raises on download or Essentia failure
    detected_bpm, confidence = bp._analyze_preview(sample_url, es)
    chosen_bpm = bp._accept_detected_bpm(detected_bpm, confidence)
    cache.put_verified_bpm(
        bp_track_id, sample_url, declared_bpm, detected_bpm, confidence, chosen_bpm,
    )
    decision = _explain_decision(detected_bpm, confidence)
    return {
        "declared_bpm": declared_bpm,
        "detected_bpm": detected_bpm,
        "confidence":   confidence,
        "chosen_bpm":   chosen_bpm,
        "decision":     decision,
    }


# ── Output formatting ──────────────────────────────────────────────────────────

def _print_track(
    idx: int,
    discogs_track,
    bp_entry: dict | None,
    analysis: dict,
) -> None:
    pos   = discogs_track.getPosition() or "?"
    title = discogs_track.getTitle() or "(untitled)"

    print(f"\n  [{idx:3d}]  {pos:<4s}  {title}")

    if bp_entry is None:
        print("         Beatport: no match")
        return

    declared_bpm = bp_entry.get("bpm")
    dur_str      = _fmt_duration(bp_entry.get("duration_ms"))
    bpm_str      = str(declared_bpm) if declared_bpm is not None else "—"
    print(f"         Beatport:  {bpm_str:>5} BPM (declared, not used)   duration {dur_str}")

    det  = analysis["detected_bpm"]
    conf = analysis["confidence"]
    dec  = analysis["decision"]
    fin  = analysis["chosen_bpm"]

    if det is not None and conf is not None:
        print(f"         Essentia:  {det:>7.2f} BPM   confidence {conf:.2f}")
    else:
        print(f"         Essentia:  —")

    print(f"         Decision:  {dec}")
    print(f"         Final BPM: {fin if fin is not None else '—'}")


# ── Main ───────────────────────────────────────────────────────────────────────

def main() -> None:
    parser = argparse.ArgumentParser(
        prog="dt_bpm",
        description="Report Beatport and Essentia BPM data for each track of a Discogs release.",
    )
    parser.add_argument("release_id", metavar="RELEASE_ID", help="Discogs release ID")
    parser.add_argument(
        "--force",
        action="store_true",
        help="Ignore cached nomatch; force a fresh Beatport search",
    )
    parser.add_argument(
        "--reverify",
        action="store_true",
        help="Re-download previews and re-run Essentia (ignores bpm_verified cache)",
    )
    parser.add_argument(
        "-v", "--verbose",
        action="store_true",
        help="Enable debug logging to stderr",
    )
    args = parser.parse_args()

    log_level = logging.DEBUG if args.verbose else logging.WARNING
    logging.basicConfig(level=log_level, stream=sys.stderr)

    release_id = str(args.release_id)

    # ── Load Discogs release ───────────────────────────────────────────────────
    try:
        dr = DiscogsRelease(int(release_id))
        artist = dr.getArtist()
        title  = dr.getTitle()
        label  = dr.getLabel()
        catno  = dr.getCatno()
        year   = dr.getYear()
    except ClientException as exc:
        print(f"Error fetching Discogs release {release_id}: {exc}", file=sys.stderr)
        sys.exit(1)

    print(f"\nRelease {release_id}: {artist} — {title}")
    print(f"  Label: {label}   Catno: {catno}   Year: {year}")

    # ── Collect all Discogs tracks ─────────────────────────────────────────────
    discogs_tracks: list[tuple[int, object]] = []
    for i in range(200):
        try:
            t = dr.getTrack(i)
            if t is None:
                break
            discogs_tracks.append((i, t))
        except (IndexError, AttributeError, ClientException):
            break

    if not discogs_tracks:
        print("No tracks found on this Discogs release.")
        sys.exit(0)

    # ── Find Beatport match ────────────────────────────────────────────────────
    print()
    cache = bp.BeatportCache()

    # Use find_bpms(verify=False) to run the matcher cascade and cache the match,
    # then pull back the beatport_id so we can re-run the pipeline ourselves for
    # the detailed per-track report.
    matcher = bp.BeatportMatcher()
    matcher.find_bpms(dr, force=args.force, verify=False)

    cached_match = cache.get_match(release_id)
    if cached_match is None:
        print("No Beatport match found for this release.")
        sys.exit(0)

    beatport_id, confidence, matcher_name = cached_match
    print(
        f"Beatport match: release {beatport_id}  "
        f"(confidence={confidence:.2f}, via {matcher_name})"
    )

    # ── Fetch raw Beatport track data ──────────────────────────────────────────
    try:
        client = bp.get_client()
    except bp.BeatportError as exc:
        print(f"Cannot connect to Beatport: {exc}", file=sys.stderr)
        sys.exit(1)

    release_data = bp._fetch_full_release(beatport_id, client, cache)
    if release_data is None:
        print("Could not fetch Beatport release data.")
        sys.exit(1)

    beatport_tracks = release_data.get("tracks", [])
    if not beatport_tracks:
        print("Beatport release has no tracks.")
        sys.exit(0)

    # raw_track_data: {discogs_idx: {bpm, duration_ms, sample_url, beatport_track_id}}
    raw_track_data = bp._match_tracks(dr, beatport_tracks)

    # ── Print per-track report ─────────────────────────────────────────────────
    bp_match_count   = 0
    essentia_checked = 0
    overridden_count = 0

    print(f"\n{'─' * 70}")
    print(f"  {'Idx':>3}  {'Pos':<4}  Track")
    print(f"{'─' * 70}")

    for idx, dt in discogs_tracks:
        bp_entry = raw_track_data.get(idx)

        analysis = None
        if bp_entry is not None:
            bp_match_count += 1
            analysis = _run_essentia_for_track(idx, bp_entry, cache, args.reverify)
            if analysis["detected_bpm"] is not None:
                essentia_checked += 1
            if (
                analysis["declared_bpm"] is not None
                and analysis["chosen_bpm"] is not None
                and analysis["declared_bpm"] != analysis["chosen_bpm"]
            ):
                overridden_count += 1

        _print_track(idx, dt, bp_entry, analysis)

    # ── Summary ────────────────────────────────────────────────────────────────
    total = len(discogs_tracks)
    print(f"\n{'─' * 70}")
    print(
        f"  Tracks: {total}   Beatport matches: {bp_match_count}"
        f"   Essentia analyzed: {essentia_checked}   Overridden: {overridden_count}"
    )
    print()


if __name__ == "__main__":
    main()
