#!/usr/bin/env python3
"""dt_server — Local HTTP bridge for the Discogs Label Printer Firefox extension.

Listens on localhost only. Accepts print/preview requests from the extension
and delegates to dt_label.

Usage:
    ./dt_server [--port PORT]

Default port: 5679 (configurable; must match the extension setting).
"""

import sys
import os
import atexit
import shutil
import argparse
import tempfile
import subprocess
import glob

from flask import Flask, request, jsonify, send_from_directory

# ── Setup ─────────────────────────────────────────────────────────────────────

SCRIPT_DIR   = os.path.dirname(os.path.abspath(__file__))
DT_LABEL     = os.path.join(SCRIPT_DIR, "dt_label")
DEFAULT_PORT = 5679

app = Flask(__name__)

# Persistent directory for preview PNGs, served over HTTP.
# Cleared on each new preview request and on server exit.
PREVIEW_DIR = tempfile.mkdtemp(prefix="dt_label_previews_")
atexit.register(shutil.rmtree, PREVIEW_DIR, ignore_errors=True)


# ── CORS (allow requests from any moz-extension:// origin) ───────────────────

@app.after_request
def add_cors(response):
    origin = request.headers.get("Origin", "")
    if origin.startswith("moz-extension://"):
        response.headers["Access-Control-Allow-Origin"]  = origin
        response.headers["Access-Control-Allow-Methods"] = "GET, POST, OPTIONS"
        response.headers["Access-Control-Allow-Headers"] = "Content-Type"
    return response

@app.route("/print",   methods=["OPTIONS"])
@app.route("/status",  methods=["OPTIONS"])
@app.route("/preview", methods=["OPTIONS"])
def preflight():
    return "", 204


# ── Endpoints ─────────────────────────────────────────────────────────────────

@app.route("/status", methods=["GET"])
def status():
    return jsonify({
        "ok":        True,
        "version":   "1.0",
        "discogs":   _check_discogs(),
        "beatport":  _check_beatport(),
        "anthropic": _check_anthropic(),
        "llm":       _check_llm(),
    })


def _check_service(fn):
    """Call fn(); translate ImportError → unavailable, other exceptions → error."""
    try:
        return fn()
    except ImportError:
        return {"status": "unavailable"}
    except Exception as e:
        return {"status": "error", "message": str(e)}


def _check_discogs():
    """Check whether Discogs OAuth tokens are stored and readable."""
    return _check_service(_do_check_discogs)


def _do_check_discogs():
    import client_interface
    token, secret = client_interface.get_user_auth_tokens()
    if token and secret:
        return {"status": "ok"}
    return {"status": "error", "message": "not authenticated"}


def _check_beatport():
    """Check Beatport credential health without making a full API call.

    Calls get_client(), which auto-refreshes the OAuth token if the stored
    username/password are still valid.  Returns a status dict.
    """
    return _check_service(_do_check_beatport)


def _do_check_beatport():
    import beatport
    beatport.get_client()
    return {"status": "ok"}


def _check_anthropic():
    """Check whether an Anthropic API key is configured."""
    return _check_service(_do_check_anthropic)


def _do_check_anthropic():
    import json
    import util
    auth_file = util.userfile("beatport_auth.json")
    api_key = None
    if os.path.exists(auth_file):
        with open(auth_file) as f:
            data = json.load(f)
        api_key = data.get("anthropic_api_key")
    if not api_key:
        api_key = os.environ.get("ANTHROPIC_API_KEY")
    if api_key:
        return {"status": "ok"}
    return {"status": "error", "message": "no API key configured"}


def _check_llm():
    """Check whether the dt_find LLM backend is configured and reachable.

    Reads ~/.discogstool/find_config to determine the active backend
    (local or anthropic), then verifies the required credentials/connectivity.
    Returns a status dict with an extra 'backend' key for UI labelling.
    """
    return _check_service(_do_check_llm)


def _do_check_llm():
    import json as _json
    import util
    config: dict = {}
    path = util.userfile("find_config")
    if os.path.exists(path):
        with open(path) as f:
            for line in f:
                line = line.strip()
                if "=" in line and not line.startswith("#"):
                    k, v = line.split("=", 1)
                    config[k.strip()] = v.strip()

    backend = config.get("backend", "local")

    if backend == "anthropic":
        # Re-use the same key lookup as _do_check_anthropic()
        auth_file = util.userfile("beatport_auth.json")
        api_key = None
        if os.path.exists(auth_file):
            with open(auth_file) as f:
                data = _json.load(f)
            api_key = data.get("anthropic_api_key")
        if not api_key:
            api_key = os.environ.get("ANTHROPIC_API_KEY")
        if api_key:
            return {"status": "ok", "backend": "anthropic"}
        return {"status": "error", "message": "no Anthropic API key configured",
                "backend": "anthropic"}

    else:  # local OpenAI-compatible server
        llm_url = config.get("llm_url", "")
        if not llm_url:
            return {"status": "error", "message": "no LLM URL configured",
                    "backend": "local"}
        try:
            import requests as _req
            _req.get(f"{llm_url}/models", timeout=2)
            return {"status": "ok", "backend": "local"}
        except Exception as e:
            return {"status": "error",
                    "message": f"LLM server unreachable: {e}",
                    "backend": "local"}


@app.route("/preview/<path:filename>", methods=["GET"])
def serve_preview(filename):
    """Serve a previously generated preview PNG."""
    return send_from_directory(PREVIEW_DIR, filename)


@app.route("/print", methods=["POST"])
def print_label():
    data = request.get_json(force=True)

    release_id = str(data.get("release_id", "")).strip()
    profile    = str(data.get("profile", "dk1247")).strip()
    preview    = bool(data.get("preview", False))
    split      = bool(data.get("split", False))
    discs      = data.get("discs")   # list of ints or None

    if not release_id.isdigit():
        return jsonify({"ok": False, "message": f"Invalid release ID: {release_id!r}"}), 400

    if preview:
        return _run_preview(release_id, profile, split=split, discs=discs)
    else:
        return _run_print(release_id, profile, split=split, discs=discs)


# ── Helpers ───────────────────────────────────────────────────────────────────

def _run_dt_label(args, *, capture=False):
    """Run dt_label with the given argument list.
    Returns (returncode, stdout+stderr combined).
    """
    cmd = [sys.executable, DT_LABEL] + args
    result = subprocess.run(
        cmd,
        capture_output=capture,
        text=True,
        cwd=SCRIPT_DIR,
    )
    output = ""
    if capture:
        output = (result.stdout or "") + (result.stderr or "")
    return result.returncode, output


def _split_args(split, discs):
    """Build --split / --discs argument fragments."""
    args = []
    if split:
        args.append("--split")
    if split and discs:
        args += ["--discs"] + [str(d) for d in discs]
    return args


def _run_print(release_id, profile, split=False, discs=None):
    rc, output = _run_dt_label(
        ["--label-profile", profile] + _split_args(split, discs) + [release_id]
    )
    if rc != 0:
        return jsonify({"ok": False, "message": output or f"dt_label exited {rc}"}), 500
    return jsonify({"ok": True})


def _run_preview(release_id, profile, split=False, discs=None):
    # Clear any previous previews
    for old in glob.glob(os.path.join(PREVIEW_DIR, "*.png")):
        try:
            os.remove(old)
        except OSError:
            pass

    rc, output = _run_dt_label([
        "--preview",
        "--label-profile", profile,
        "--output", PREVIEW_DIR,
    ] + _split_args(split, discs) + [release_id], capture=True)

    if rc != 0:
        return jsonify({"ok": False, "message": output or f"dt_label exited {rc}"}), 500

    pngs = sorted(glob.glob(os.path.join(PREVIEW_DIR, "*.png")))
    if not pngs:
        return jsonify({"ok": False, "message": "dt_label produced no PNG"}), 500

    urls = [f"/preview/{os.path.basename(p)}" for p in pngs]
    return jsonify({"ok": True, "preview_urls": urls})


# ── Entry point ───────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--port", type=int, default=DEFAULT_PORT,
                        help=f"Port to listen on (default: {DEFAULT_PORT})")
    args = parser.parse_args()

    print(f"dt_server listening on http://localhost:{args.port}")
    print("Press Ctrl-C to stop.")

    app.run(host="127.0.0.1", port=args.port, debug=False)


if __name__ == "__main__":
    main()
